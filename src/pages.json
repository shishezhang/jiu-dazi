{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "酒搭子",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/discover/discover",
      "style": {
        "navigationBarTitleText": "发现搭子",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/match/match",
      "style": {
        "navigationBarTitleText": "匹配",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/event/create",
      "style": {
        "navigationBarTitleText": "发起酒局"
      }
    },
    {
      "path": "pages/event/detail",
      "style": {
        "navigationBarTitleText": "酒局详情"
      }
    },
    {
      "path": "pages/event/list",
      "style": {
        "navigationBarTitleText": "附近酒局"
      }
    },
    {
      "path": "pages/chat/chat",
      "style": {
        "navigationBarTitleText": "聊天"
      }
    },
    {
      "path": "pages/chat/list",
      "style": {
        "navigationBarTitleText": "消息"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/profile/edit",
      "style": {
        "navigationBarTitleText": "编辑资料"
      }
    },
    {
      "path": "pages/profile/settings",
      "style": {
        "navigationBarTitleText": "设置"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "酒搭子",
    "navigationBarBackgroundColor": "#1a1a2e",
    "backgroundColor": "#0f0f1a",
    "backgroundColorTop": "#0f0f1a",
    "backgroundColorBottom": "#0f0f1a"
  },
  "tabBar": {
    "color": "#666680",
    "selectedColor": "#e94560",
    "backgroundColor": "#1a1a2e",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/discover/discover",
        "iconPath": "static/tab/discover.png",
        "selectedIconPath": "static/tab/discover-active.png",
        "text": "发现"
      },
      {
        "pagePath": "pages/match/match",
        "iconPath": "static/tab/match.png",
        "selectedIconPath": "static/tab/match-active.png",
        "text": "匹配"
      },
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tab/event.png",
        "selectedIconPath": "static/tab/event-active.png",
        "text": "酒局"
      },
      {
        "pagePath": "pages/chat/list",
        "iconPath": "static/tab/chat.png",
        "selectedIconPath": "static/tab/chat-active.png",
        "text": "消息"
      },
      {
        "pagePath": "pages/profile/profile",
        "iconPath": "static/tab/profile.png",
        "selectedIconPath": "static/tab/profile-active.png",
        "text": "我的"
      }
    ]
  },
  "preloadRule": {
    "pages/discover/discover": {
      "network": "all",
      "packages": ["pages/match/match", "pages/event/detail"]
    }
  }
}
